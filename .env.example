# ZingAPI / Guangdada API
# Copy values from ZingAPI admin console into .env. Do not commit real secrets.
ZINGAPI_CUSTOMER_NAME=your_customer_name
ZINGAPI_ACCESS_KEY_ID=your_access_key_id
ZINGAPI_ACCESS_KEY_SECRET=your_access_key_secret

# Optional, defaults shown below.
ZINGAPI_HOST=openapi.dataideaglobal.com
ZINGAPI_VERSION=v1
